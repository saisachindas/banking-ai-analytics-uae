# Database Configuration
DB_URL=postgresql://postgres:password@localhost:5432/uae_banking
# For SQLite local development, use: sqlite:///./uae_banking.db

# HuggingFace Token (for private models, optional)
HF_TOKEN=your_huggingface_token_here

# OpenAI API Key (optional, currently using open-source models)
OPENAI_API_KEY=

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/banking_ai.log

# Model Configuration
LLM_MODEL_NAME=google/flan-t5-large
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Application Settings
DEBUG=False
ENVIRONMENT=development
