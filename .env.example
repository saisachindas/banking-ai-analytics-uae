# Environment Variables Configuration
# Copy this to .env and update with your actual values

# Database
DB_URL=sqlite:///./uae_banking.db
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Environment
ENVIRONMENT=development
DEBUG=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/banking_ai.log

# Models
MODEL_DEVICE=cpu
TEXT_GENERATION_MODEL=google/flan-t5-base
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SUMMARIZATION_MODEL=facebook/bart-large-cnn

# Analytics
FRAUD_CONTAMINATION=0.05
SEGMENTATION_CLUSTERS=4
CREDIT_RISK_THRESHOLD=0.5

# API (Optional)
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Azure (Optional)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_STORAGE_ACCOUNT=

# AWS (Optional)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
